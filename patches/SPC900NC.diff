+++ b/drivers/video/v4l2driver.cpp
@@ -941,11 +941,30 @@ bool V4L2_Driver::StartExposure(float duration)
         }
     }
 
-    return is_capturing;
+    /* For LX modes other than SERIAL (e.g. LED), capturing is deferred
+     * until the LX timer fires (see lxtimerCallback), so is_capturing is
+     * still false at this point. We must return true so that the base class
+     * sets PrimaryCCD to IPS_BUSY, otherwise PrimaryCCD.isExposing() will
+     * return false when the frame arrives and the driver will abort with
+     * "frame received while not exposing". */
+    return is_capturing || (lx->isEnabled() && lx->getLxmode() != LXSERIAL);
 }
 
 bool V4L2_Driver::setShutter(double duration)
 {
+    /* Initialize exposure counters for all paths (LX and manual).
+     * Previously these were only set in the manual exposure path,
+     * leaving them uninitialized for LX exposures. This caused
+     * getRemainingExposure() and frame timing logic in newFrame()
+     * to operate on stale/garbage values during LX captures. */
+    exposure_duration.tv_sec  = (long) duration;
+    exposure_duration.tv_usec = (long) ((duration - (double) exposure_duration.tv_sec) * 1000000.0f);
+
+    elapsed_exposure.tv_sec = 0;
+    elapsed_exposure.tv_usec = 0;
+
+    gettimeofday(&capture_start, nullptr);
+
     if (lx->isEnabled())
     {
         LOGF_INFO("Using long exposure mode for %.3f sec frame.", duration);
@@ -963,14 +982,6 @@ bool V4L2_Driver::setShutter(double duration)
